# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# graphify — local AST cache + machine markers are generated and should never be
# tracked (the human/AI-readable graph outputs under graphify-out/ can stay).
# Already-tracked cache files still need one-time: git rm -r --cached graphify-out/cache
graphify-out/cache/
graphify-out/.graphify_*
